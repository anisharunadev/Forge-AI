{
  "name": "forge-ai/mcp-github",
  "version": "0.1.0",
  "description": "FORA GitHub MCP server — exposes list_repos, get_pr, list_prs, create_pr_comment, list_issues, create_issue, search_code over MCP/stdio. Auth via GitHub App or PAT scoped to a single org.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fora-mcp-github": "bin/fora-mcp-github.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node bin/fora-mcp-github.mjs",
    "smoke": "node test/smoke.mjs",
    "smoke:live": "node test/live-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
