{
  "name": "forge-ai/mcp-figma",
  "version": "0.1.0",
  "description": "FORA Figma MCP server — exposes get_file, get_file_nodes, get_node, get_images, get_comments, post_comment over MCP/stdio. Auth via Figma personal access token, pinned to a single file and team.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fora-mcp-figma": "bin/fora-mcp-figma.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node bin/fora-mcp-figma.mjs",
    "smoke": "node test/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
