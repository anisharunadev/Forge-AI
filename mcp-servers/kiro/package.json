{
  "name": "@forge-ai/mcp-kiro",
  "version": "0.1.0",
  "description": "Forge AI Kiro IDE MCP server — exposes get_open_files, get_current_selection, get_active_task_queue, get_agent_run_history over MCP/stdio. Auth via Kiro daemon socket or local HTTP API. Spec is emerging; the client is abstracted behind a typed interface so the transport can be swapped without touching tool contracts.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kiro-mcp": "bin/kiro-mcp.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node bin/kiro-mcp.mjs",
    "test": "node --import tsx --test test/unit.test.ts test/integration.test.ts",
    "test:unit": "node --import tsx --test test/unit.test.ts",
    "test:integration": "node --import tsx --test test/integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
