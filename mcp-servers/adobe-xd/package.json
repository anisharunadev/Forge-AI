{
  "name": "@forge-ai/mcp-adobe-xd",
  "version": "0.1.0",
  "description": "Forge AI Adobe XD MCP server — exposes get_asset, list_components, export_spec, get_design_tokens over MCP/stdio. Auth via OAuth2 (Adobe IMS), pinned to a single XD file and project.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "adobe-xd-mcp": "bin/adobe-xd-mcp"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node bin/adobe-xd-mcp",
    "smoke": "node test/smoke.mjs",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/integration.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
