{
  "name": "forge-ai/mcp-sonarqube",
  "version": "0.1.0",
  "description": "FORA SonarQube MCP server — exposes list_projects, get_project, search_components, get_component_measures, list_issues, get_issue, transition_issue, get_quality_gate over MCP/stdio. Pinned to a single project. Auth via SonarQube user token.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fora-mcp-sonarqube": "bin/fora-mcp-sonarqube.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node bin/fora-mcp-sonarqube.mjs",
    "smoke": "node test/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0"
  }
}
