{
  "name": "forge-ai/mcp-secrets",
  "version": "0.1.0",
  "description": "FORA secrets-mcp — exposes resolve(secret_ref) and rotate(secret_ref) over MCP/stdio. Returns a redacted envelope to the agent; raw values never cross the broker boundary. See ADR-0003 §7 and FORA-128.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fora-mcp-secrets": "bin/fora-mcp-secrets.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "node bin/fora-mcp-secrets.mjs",
    "smoke": "node test/smoke.mjs",
    "test": "node test/unit.mjs && node test/unit-aws.mjs && node test/unit-audit.mjs && node test/unit-brokered.mjs && node test/property/memory-dump.mjs",
    "test:memory": "node test/unit.mjs",
    "test:aws": "node test/unit-aws.mjs",
    "test:audit": "node test/unit-audit.mjs",
    "test:brokered": "node test/unit-brokered.mjs",
    "test:property": "node test/property/memory-dump.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.658.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0"
  }
}
