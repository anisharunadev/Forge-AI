{
  "name": "@fora/event-bus-bridge",
  "version": "0.1.0",
  "description": "FORA event-bus bridge — subscribes to NATS JetStream per-tenant streams, republishes each event verbatim to an SNS topic so the audit account (separate AWS account) can ingest via SQS. v1 per ADR-0006 §5.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fora-event-bus-bridge": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "engencies": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.658.0",
    "@fora/event-bus": "workspace:*",
    "nats": "^2.28.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "aws-sdk-client-mock": "^4.0.1",
    "aws-sdk-client-mock-vitest": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
