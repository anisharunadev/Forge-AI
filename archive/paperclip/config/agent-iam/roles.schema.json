{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fora.local/schemas/agent-iam/roles.schema.json",
  "title": "FORA Agent IAM Role Registry",
  "description": "Static role registry for FORA sub-agents (FORA-125 / 0.7.3).",
  "type": "object",
  "required": ["version", "mcps", "scopes", "roles"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Bumped only on a breaking shape change."
    },
    "mcps": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
      },
      "description": "Closed list of MCP names known to the platform. The CI lint fails if a role references an MCP not in this list, or if an MCP here is referenced by no role."
    },
    "scopes": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z]+(:[a-z0-9-]+)?$"
      },
      "description": "Closed scope vocabulary. Format is `<verb>` or `<verb>:<noun>`."
    },
    "roles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["mcps", "scopes"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "mcps": {
            "type": "array",
            "minItems": 0,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" }
          },
          "scopes": {
            "type": "array",
            "minItems": 0,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z]+(:[a-z0-9-]+)?$" }
          },
          "deny_scopes": {
            "type": "array",
            "minItems": 0,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z]+(:[a-z0-9-]+)?$" }
          }
        }
      }
    }
  }
}
