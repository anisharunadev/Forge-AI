# Load-test fixture for FORA-267 / Epic 11.6 outbound burst control
#
# Replayable by `python -m forge.sync_plane.burst.tests.test_smoke`
# (which reads the rate parameters below at the top of `test_load`).
#
# Scenario:  3 tenants × 3 platforms (Jira / GitHub / ClickUp) × 60 s
# Rate:      3× expected per-tenant event rate (5 ev/s baseline → 15 ev/s)
# Total:     900 events / (tenant × platform) = 8100 events overall
#
# Pass criteria (FORA-267 AC #2):
#   - all 8100 events DISPATCHED (no drops)
#   - worst-case p99 queue latency < 200 ms
#
# Bucket / breaker / queue defaults used in this fixture:
expected_rate_hz_per_tenant = 5
load_multiplier             = 3
duration_seconds            = 60
tenants                     = ["t1", "t2", "t3"]
platforms                   = ["jira", "github", "clickup"]
bucket_capacity             = 40.0
bucket_refill_per_s         = 20.0
queue_max_depth             = 100000
breaker_fail_threshold      = 10
breaker_window_ms           = 10000
breaker_cooldown_ms         = 30000
coalesce_window_ms          = 250
tick_ms                     = 10
drain_every_n_ticks         = 5
#
# The fixture is *parametric*: the test reads these constants and the
# evidence row in the issue PATCH records the observed
# (events_dispatched, p99_latency_ms) tuple.
</file>

