# FORA-188 / FORA-128.e — gitleaks rule set.
#
# The CI already invokes gitleaks via `gitleaks/gitleaks-action@v2`
# (see .github/workflows/ci.yml). This file tightens the default
# rule set to FORA-specific patterns so the action fails on:
#
#   - GitHub personal access tokens (ghp_, gho_, ghu_, ghs_)
#   - AWS access key IDs (AKIA / ASIA prefixes)
#   - OpenAI / Anthropic API keys
#   - Slack tokens (xox[boprs]-)
#   - Stripe live keys (sk_live_, rk_live_)
#   - Vault service tokens (hvs., hvb., s.)
#   - Private-key headers (BEGIN ... PRIVATE KEY)
#   - Generic high-entropy base64 / hex strings
#
# Rule set follows the gitleaks v8 schema. Each `[[rules]]` block is
# a single pattern with allowlists for the test fixtures
# (`tools/gitleaks/fixtures/`) and the well-known false-positive
# paths.

title = "FORA gitleaks config"

[extend]
# We extend gitleaks' built-in default rules so the action still
# catches the upstream-known patterns (npm, JWT, etc.).
useDefault = true

# ─────────────────────────────────────────────────────────────────────
# FORA-specific rules. The regex syntax is RE2; see
# https://github.com/gitleaks/gitleaks/blob/master/CONFIGURATION.md
# ─────────────────────────────────────────────────────────────────────

[[rules]]
id = "fora-github-pat"
description = "GitHub personal access token (ghp_/gho_/ghu_/ghs_)"
regex = '''\b((ghp|gho|ghu|ghs)_[A-Za-z0-9]{36,251})\b'''
keywords = ["ghp_", "gho_", "ghu_", "ghs_"]
tags = ["github", "pat", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
    '''tools/lint-secrets-blocks/fixtures/.*''',
    '''docs/runbooks/secrets-mcp.md''',
    '''docs/architecture/adr-0003-auth-tenancy.md''',
    '''mcp-servers/secrets/test/.*\.mjs''',
    '''mcp-servers/secrets/docs/contract.md''',
    '''mcp-servers/secrets/docs/runbook.md''',
  ]

[[rules]]
id = "fora-aws-access-key"
description = "AWS access key ID"
regex = '''\b((AKIA|ASIA)[0-9A-Z]{16})\b'''
keywords = ["AKIA", "ASIA"]
tags = ["aws", "access-key", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
    '''tools/lint-secrets-blocks/fixtures/.*''',
    '''mcp-servers/secrets/test/.*\.mjs''',
    '''mcp-servers/secrets/src/store-aws\.ts''',
    '''mcp-servers/secrets/docs/.*\.md''',
    '''docs/runbooks/secrets-mcp.md''',
  ]

[[rules]]
id = "fora-anthropic-api-key"
description = "Anthropic API key (sk-ant-…)"
regex = '''\b(sk-ant-[A-Za-z0-9_-]{32,})\b'''
keywords = ["sk-ant-"]
tags = ["anthropic", "api-key", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
    '''mcp-servers/secrets/test/.*\.mjs''',
    '''docs/.*\.md''',
  ]

[[rules]]
id = "fora-openai-api-key"
description = "OpenAI API key (sk-…)"
regex = '''\b(sk-[A-Za-z0-9]{20,}T3BlbkFJ[A-Za-z0-9]{20,})\b'''
keywords = ["T3BlbkFJ"]
tags = ["openai", "api-key", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
    '''mcp-servers/secrets/test/.*\.mjs''',
  ]

[[rules]]
id = "fora-slack-token"
description = "Slack token (xox[boprs]-…)"
regex = '''\b(xox[boprs]-[A-Za-z0-9-]{10,})\b'''
keywords = ["xoxb-", "xoxp-", "xoxr-", "xoxs-", "xoxo-"]
tags = ["slack", "token", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
    '''mcp-servers/secrets/test/.*\.mjs''',
  ]

[[rules]]
id = "fora-stripe-live-key"
description = "Stripe live secret / restricted key"
regex = '''\b((sk|rk)_live_[A-Za-z0-9]{20,})\b'''
keywords = ["sk_live_", "rk_live_"]
tags = ["stripe", "live-key", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
    '''mcp-servers/secrets/test/.*\.mjs''',
  ]

[[rules]]
id = "fora-vault-service-token"
description = "Vault service token (hvs./hvb./s.)"
regex = '''\b((hvs|hvb)\.[A-Za-z0-9_-]{20,}|s\.[A-Za-z0-9]{20,})\b'''
keywords = ["hvs.", "hvb.", "s."]
tags = ["vault", "token", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
    '''mcp-servers/secrets/test/.*\.mjs''',
  ]

[[rules]]
id = "fora-private-key-header"
description = "PEM private key header"
regex = '''-----BEGIN ((RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY|CERTIFICATE)-----'''
keywords = ["BEGIN PRIVATE KEY", "BEGIN RSA PRIVATE KEY", "BEGIN EC PRIVATE KEY"]
tags = ["private-key", "pem", "fora"]

  [rules.allowlist]
  paths = [
    '''tools/gitleaks/fixtures/.*''',
  ]
</file>

<file path=".repomixignore">
