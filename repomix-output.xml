    parameters:
      - in: path
        name: issue_id
        required: true
        schema: { type: string, format: uuid }
    post:
      tags: [issues]
      summary: Comment on an issue
      operationId: postIssueComment
      parameters:
        - $ref: '#/components/parameters/IdempotencyKey'
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: '#/components/schemas/CreateComment' }
      responses:
        '201':
          description: Comment created.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/Comment' }

  /issues/{issue_id}/interactions:
    parameters:
      - in: path
        name: issue_id
        required: true
        schema: { type: string, format: uuid }
    post:
      tags: [issues]
      summary: Create an interaction on an issue (suggest_tasks, ask_user_questions, request_confirmation)
      operationId: createIssueInteraction
      parameters:
        - $ref: '#/components/parameters/IdempotencyKey'
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: '#/components/schemas/CreateInteractionRequest' }
      responses:
        '201':
          description: Interaction created.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/Interaction' }

  # -----------------------------------------------------------------------
  # Cloud broker
  # -----------------------------------------------------------------------
  /tenants/{tenant_id}/cloud/assume:
    parameters:
      - in: path
        name: tenant_id
        required: true
        schema: { type: string, format: uuid }
    post:
      tags: [cloud-broker]
      summary: Assume a short-lived cloud role for this tenant
      operationId: cloudAssume
      parameters:
        - $ref: '#/components/parameters/IdempotencyKey'
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: '#/components/schemas/AssumeRequest' }
      responses:
        '200':
          description: Scoped credentials + handle.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/AssumeResponse' }
        '403':
          description: DENY_LIST_HIT or out-of-allow-list.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/Error' }
        '503':
          description: CIRCUIT_OPEN for (tenant, provider).
          content:
            application/json:
              schema: { $ref: '#/components/schemas/Error' }

  /tenants/{tenant_id}/cloud/release:
    parameters:
      - in: path
        name: tenant_id
        required: true
        schema: { type: string, format: uuid }
    post:
      tags: [cloud-broker]
      summary: Release a previously-assumed handle (idempotent)
      operationId: cloudRelease
      parameters:
        - $ref: '#/components/parameters/IdempotencyKey'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required: [handle_id]
              properties:
                handle_id: { type: string, format: uuid }
      responses:
        '204': { description: Released. }

  /tenants/{tenant_id}/cloud/probe:
    parameters:
      - in: path
        name: tenant_id
        required: true
        schema: { type: string, format: uuid }
    get:
      tags: [cloud-broker]
      summary: Internal canary probe (system-only; every 5 min)
      operationId: cloudProbe
      responses:
        '200':
          description: Probe result.
          content:
            application/json:
              schema:
                type: object
                required: [provider, ok]
                properties:
                  provider: { type: string, enum: [aws, azure, gcp] }
                  ok: { type: boolean }
                  error: { type: string, nullable: true }
                  latency_ms: { type: integer, nullable: true }

  # -----------------------------------------------------------------------
  # Audit (read surface; lives in the audit account)
  # -----------------------------------------------------------------------
  /tenants/{tenant_id}/audit/runs:
    parameters:
      - in: path
        name: tenant_id
        required: true
        schema: { type: string, format: uuid }
    get:
      tags: [audit]
      summary: List runs visible to this caller (filterable)
      operationId: auditListRuns
      parameters:
        - in: query
          name: date_from
          schema: { type: string, format: date-time }
        - in: query
          name: date_to
          schema: { type: string, format: date-time }
        - in: query
          name: actor
          schema: { type: string, description: "Match by `agent:%`, `user:%`, or `system:%`" }
        - in: query
          name: tool
          schema: { type: string }
        - $ref: '#/components/parameters/Limit'
        - $ref: '#/components/parameters/Cursor'
      responses:
        '200':
          description: Page of audit rows.
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AuditPage'

  /tenants/{tenant_id}/audit/exports:
    parameters:
      - in: path
        name: tenant_id
        required: true
        schema: { type: string, format: uuid }
    post:
      tags: [audit]
      summary: Export filtered audit rows to a customer-GPG-encrypted CSV
      operationId: auditExport
      parameters:
        - $ref: '#/components/parameters/IdempotencyKey'
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: '#/components/schemas/AuditExportRequest' }
      responses:
        '202':
          description: Export job accepted.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/AuditExportAccepted' }

  # -----------------------------------------------------------------------
  # OAuth + IdP webhook
  # -----------------------------------------------------------------------
  /oauth/{tenant_slug}/authorize:
    parameters:
      - in: path
        name: tenant_slug
        required: true
        schema: { type: string }
    get:
      tags: [oauth]
      summary: OIDC authorize endpoint
      operationId: oauthAuthorize
      parameters:
        - in: query
          name: response_type
          required: true
          schema: { type: string, enum: [code] }
        - in: query
          name: client_id
          required: true
          schema: { type: string }
        - in: query
          name: redirect_uri
          required: true
          schema: { type: string, format: uri }
        - in: query
          name: scope
          schema: { type: string }
        - in: query
          name: state
          required: true
          schema: { type: string }
        - in: query
          name: code_challenge
          schema: { type: string }
        - in: query
          name: code_challenge_method
          schema: { type: string, enum: [S256] }
      responses:
        '302':
          description: Redirect to IdP.
          headers:
            Location: { schema: { type: string, format: uri } }
        '400': { $ref: '#/components/responses/BadRequest' }

  /oauth/{tenant_slug}/token:
    parameters:
      - in: path
        name: tenant_slug
        required: true
        schema: { type: string }
    post:
      tags: [oauth]
      summary: "OIDC token endpoint (RFC 6749). NOTE: this endpoint does NOT use the platform Idempotency-Key header; the OIDC grant types enforce their own idempotency (`authorization_code` is single-use, `refresh_token` returns the same access token until rotation, `client_credentials` is naturally idempotent)."
      operationId: oauthToken
      requestBody:
        required: true
        content:
          application/x-www-form-urlencoded:
            schema:
              type: object
              required: [grant_type]
              properties:
                grant_type: { type: string, enum: [authorization_code, refresh_token, client_credentials] }
                code: { type: string }
                redirect_uri: { type: string, format: uri }
                client_id: { type: string }
                client_secret: { type: string }
                refresh_token: { type: string }
                code_verifier: { type: string }
      responses:
        '200':
          description: Token bundle.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/TokenResponse' }
        '401': { $ref: '#/components/responses/Unauthorized' }

  /webhooks/idp-revoke:
    post:
      tags: [oauth]
      summary: "IdP revocation webhook (HMAC-SHA256, `X-IdP-Signature: sha256=<hex>`)"
      operationId: idpRevokeWebhook
      parameters:
        - in: header
          name: X-IdP-Signature
          required: true
          schema: { type: string, pattern: '^sha256=[a-f0-9]{64}$' }
        - in: header
          name: X-IdP-Timestamp
          required: true
          schema: { type: string, format: date-time }
        - $ref: '#/components/parameters/IdempotencyKey'
      requestBody:
        required: true
        content:
          application/json:
            schema:
              type: object
              required: [tenant_id, jti, action]
              properties:
                tenant_id: { type: string, format: uuid }
                jti: { type: string, description: "JWT id to revoke" }
                action: { type: string, enum: [revoke] }
                reason: { type: string }
      responses:
        '200':
          description: Revocation recorded.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/Ack' }
        '401':
          description: INVALID_SIGNATURE (HMAC mismatch).
          content:
            application/json:
              schema: { $ref: '#/components/schemas/Error' }

  /.well-known/jwks.json:
    get:
      tags: [oauth]
      summary: JWKS for the platform JWT
      operationId: jwks
      security: []
      responses:
        '200':
          description: JWKS.
          content:
            application/json:
              schema:
                type: object
                required: [keys]
                properties:
                  keys:
                    type: array
                    items: { $ref: '#/components/schemas/JWK' }

  # -----------------------------------------------------------------------
  # Events
  # -----------------------------------------------------------------------
  /events/publish:
    post:
      tags: [events]
      summary: Publish an event to the in-cluster bus (NATS) + bridge to the audit account (SQS)
      operationId: publishEvent
      parameters:
        - $ref: '#/components/parameters/IdempotencyKey'
      requestBody:
        required: true
        content:
          application/json:
            schema: { $ref: '#/components/schemas/EventPublishRequest' }
      responses:
        '202':
          description: Accepted.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/EventPublishResponse' }

  /events/{event_id}/status:
    parameters:
      - in: path
        name: event_id
        required: true
        schema: { type: string, format: uuid }
    get:
      tags: [events]
      summary: Get the delivery status of an event
      operationId: eventStatus
      responses:
        '200':
          description: Status.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/EventStatus' }

  # -----------------------------------------------------------------------
  # Health
  # -----------------------------------------------------------------------
  /healthz:
    get:
      tags: [health]
      summary: Liveness
      operationId: liveness
      security: []
      responses:
        '200':
          description: Live.
          content:
            application/json:
              schema:
                type: object
                required: [status]
                properties:
                  status: { type: string, enum: [ok] }
                  version: { type: string }

  /readyz:
    get:
      tags: [health]
      summary: Readiness (checks DB, Redis, NATS, OIDC, model provider)
      operationId: readiness
      security: []
      responses:
        '200':
          description: Ready.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/HealthCheck' }
        '503':
          description: Degraded; one or more deps are down.
          content:
            application/json:
              schema: { $ref: '#/components/schemas/HealthCheck' }

# =======================================================================
# Components
# =======================================================================
components:

  # -----------------------------------------------------------------------
  # Reusable parameters
  # -----------------------------------------------------------------------
  parameters:
    IdempotencyKey:
      in: header
      name: Idempotency-Key
      required: true
      description: UUIDv4. Same key + same body = replay (cached response). Same key + different body = 409 IDEMPOTENCY_CONFLICT. See ADR-0004.
      schema:
        type: string
        format: uuid
    RunId:
      in: path
      name: run_id
      required: true
      schema: { type: string, format: uuid }
    Limit:
      in: query
      name: limit
      schema: { type: integer, minimum: 1, maximum: 200, default: 50 }
    Cursor:
      in: query
      name: cursor
      schema: { type: string, description: "Opaque cursor returned by the prior page (next_cursor)." }

  # -----------------------------------------------------------------------
  # Reusable responses
  # -----------------------------------------------------------------------
  responses:
    BadRequest:
      description: Malformed request.
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }
    Unauthorized:
      description: Missing or invalid bearer token.
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }
    Forbidden:
      description: Authenticated, but not authorized for this resource.
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }
    NotFound:
      description: Resource not found, or not in caller's scope.
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }
    IdempotencyConflict:
      description: Same Idempotency-Key + different request fingerprint.
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }
    RateLimited:
      description: Per-tenant or per-token bucket tripped.
      headers:
        Retry-After: { schema: { type: integer } }
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }
    BudgetExceeded:
      description: BUDGET_EXCEEDED — per-run or per-tenant budget ceiling hit.
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }
    InternalError:
      description: Unexpected server error.
      content:
        application/json:
          schema: { $ref: '#/components/schemas/Error' }

  # -----------------------------------------------------------------------
  # Security schemes
  # -----------------------------------------------------------------------
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: |
        OIDC JWT issued by `apps/identity-broker`. Audience is `forge-runtime` for
        service callers and `forge-console` for the console. The token carries
        `tenant_id`, `role`, and (for the agent runtime) a `run_id` and
        `allow_list` (per architecture memory §4 + security memory §4).

  # -----------------------------------------------------------------------
  # Schemas
  # -----------------------------------------------------------------------
  schemas:

    # ---------- Error envelope ---------------------------------------------
    Error:
      type: object
      required: [error]
      properties:
        error:
          type: object
          required: [code, message, request_id]
          properties:
            code:
              type: string
              description: Stable error code. See lld.md §7 for the canonical table.
              examples: [TENANT_NOT_FOUND, IDEMPOTENCY_CONFLICT, BUDGET_EXCEEDED, TOOL_NOT_IN_ALLOW_LIST, STAGE_MISMATCH, INVALID_SIGNATURE, CIRCUIT_OPEN, INTERNAL]
            message:
              type: string
              description: Human-readable; NOT stable. Safe to display to operators, not to end users.
            request_id:
              type: string
              format: uuid
            retry_after_ms:
              type: integer
              nullable: true
              description: Hint to the client; nullable.

    # ---------- Enums ------------------------------------------------------
    RunStatus:
      type: string
      enum: [created, running, waiting_approval, paused, aborted, finished, done]
    StageStatus:
      type: string
      enum: [pending, running, waiting_approval, approved, rejected, returned, skipped]
    Stage:
      type: string
      enum: [ideation, architect, dev, qa, security, devops, docs]
    IssueStatus:
      type: string
      enum: [backlog, todo, in_progress, in_review, blocked, done, cancelled]
    TriggerKind:
      type: string
      enum: [user, slack, email, schedule, webhook]
    DecisionKind:
      type: string
      enum: [NEXT, RETURN, ABORT]
    ApprovalStatus:
      type: string
      enum: [pending, approved, rejected, expired]
    ApprovalDecisionKind:
      type: string
      enum: [accept, reject, request_changes]

    # ---------- Runs -------------------------------------------------------
    CreateRunRequest:
      type: object
      required: [goal_id, project_id, trigger]
      properties:
        goal_id: { type: string, format: uuid }
        project_id: { type: string, format: uuid }
        trigger:
          type: object
          required: [kind, actor]
          properties:
            kind: { $ref: '#/components/schemas/TriggerKind' }
            actor: { type: string, description: "user id, slack channel, email address, schedule name, etc." }
            payload_ref:
              type: string
              description: Pointer to the trigger payload (S3 key, Jira issue key, etc.)
        labels:
          type: object
          additionalProperties: { type: string }
        cost_ceiling_usd:
          type: number
          format: double
          minimum: 0
          default: 50
          description: "Per-run ceiling. Default $50 (PRD §8)."

    Run:
      type: object
      required: [id, tenant_id, status, current_stage, created_at]
      properties:
        id: { type: string, format: uuid }
        tenant_id: { type: string, format: uuid }
        status: { $ref: '#/components/schemas/RunStatus' }
        current_stage: { $ref: '#/components/schemas/Stage' }
        goal_id: { type: string, format: uuid }
        project_id: { type: string, format: uuid }
        trigger:
          type: object
          properties:
            kind: { $ref: '#/components/schemas/TriggerKind' }
            actor: { type: string }
        cost_estimate: { $ref: '#/components/schemas/Money' }
        cost_actual: { $ref: '#/components/schemas/Money' }
        cost_ceiling_usd: { type: number, format: double }
        started_at: { type: string, format: date-time, nullable: true }
        finished_at: { type: string, format: date-time, nullable: true }
        created_at: { type: string, format: date-time }
        updated_at: { type: string, format: date-time }
        labels:
          type: object
          additionalProperties: { type: string }

    RunPage:
      type: object
      required: [items]
      properties:
        items:
          type: array
          items: { $ref: '#/components/schemas/Run' }
        next_cursor: { type: string, nullable: true }
        total_estimate: { type: integer, nullable: true }

    RunContext:
      type: object
      required: [run_id, tenant_id, stage, status, allow_list]
      properties:
        run_id: { type: string, format: uuid }
        tenant_id: { type: string, format: uuid }
        stage: { $ref: '#/components/schemas/Stage' }
        status: { $ref: '#/components/schemas/StageStatus' }
        allow_list:
          type: object
          required: [allow, deny]
          properties:
            allow:
              type: array
              items:
                type: object
                required: [tool]
                properties:
                  tool: { type: string }
                  max_per_run: { type: integer, minimum: 0 }
            deny:
              type: array
              items:
                type: object
                required: [tool, reason]
                properties:
                  tool: { type: string }
                  reason: { type: string }
        inputs:
          type: array
          items: { $ref: '#/components/schemas/ArtefactRef' }
        knowledge_layer_refs:
          type: array
          items: { type: string }
          description: "Files from the Knowledge Layer the runtime should load for this stage."

    TransitionRequest:
      type: object
      required: [from_stage, to_stage, decision]
      properties:
        from_stage: { $ref: '#/components/schemas/Stage' }
        to_stage: { $ref: '#/components/schemas/Stage' }
        decision:
          type: object
          required: [kind]
          properties:
            kind: { $ref: '#/components/schemas/DecisionKind' }
            reason: { type: string }
            returned_to_stage: { $ref: '#/components/schemas/Stage' }
        artefact: { $ref: '#/components/schemas/ArtefactRef' }

    StageDecision:
      type: object
      required: [run_id, current_stage, status, event_id]
      properties:
        run_id: { type: string, format: uuid }
        current_stage: { $ref: '#/components/schemas/Stage' }
        status: { $ref: '#/components/schemas/StageStatus' }
        event_id: { type: string, format: uuid, description: "The published event_id (UUIDv7)." }

    RunStage:
      type: object
      required: [stage, status]
      properties:
        stage: { $ref: '#/components/schemas/Stage' }
        status: { $ref: '#/components/schemas/StageStatus' }
        model_provider: { type: string, enum: [anthropic, openai, failover] }
        inputs:
          type: array
          items: { $ref: '#/components/schemas/ArtefactRef' }
        outputs:
          type: array
          items: { $ref: '#/components/schemas/ArtefactRef' }
        artefact_ref: { type: string, nullable: true }
        started_at: { type: string, format: date-time, nullable: true }
        finished_at: { type: string, format: date-time, nullable: true }

    ArtefactRef:
      type: object
      required: [kind, url, sha256]
      properties:
        kind: { type: string, enum: [adr, pr, report, page, jira, runbook, plan, export] }
        url: { type: string, format: uri }
        sha256: { type: string, pattern: '^[a-f0-9]{64}$' }

    CostReport:
      type: object
      required: [stage, tokens_in, tokens_out, cost_usd]
      properties:
        stage: { $ref: '#/components/schemas/Stage' }
        tokens_in: { type: integer, minimum: 0 }
        tokens_out: { type: integer, minimum: 0 }
        cost_usd: { type: number, format: double, minimum: 0 }
        model_provider: { type: string, enum: [anthropic, openai, failover] }

    Money:
      type: object
      required: [units, nanos]
      properties:
        units: { type: integer, description: "Whole dollars (or whatever the currency's base unit is)." }
        nanos: { type: integer, minimum: 0, maximum: 999999999, description: "1e-9 of the base unit." }
        currency: { type: string, minLength: 3, maxLength: 3, default: USD }

    Ack:
      type: object
      required: [ok]
      properties:
        ok: { type: boolean }
        event_id: { type: string, format: uuid, nullable: true }

    # ---------- Approvals --------------------------------------------------
    Approval:
      type: object
      required: [id, run_id, gate_kind, required_role, status, requested_at, expires_at]
      properties:
        id: { type: string, format: uuid }
        run_id: { type: string, format: uuid }
        stage: { allOf: [ { $ref: '#/components/schemas/Stage' } ], nullable: true }
        gate_kind: { type: string, enum: ['ideation->architect', 'architect->dev', 'dev->qa', 'qa->security', 'security->devops', 'devops->docs', 'docs->done', 'launch', 'incident_mitigation'] }
        required_role: { type: string, enum: [pm, cto, ceo, qa, security, devops, docs, engineer, board] }
        status: { $ref: '#/components/schemas/ApprovalStatus' }
        paperclip_interaction_id: { type: string, nullable: true }
        artefact_refs:
          type: array
          items: { $ref: '#/components/schemas/ArtefactRef' }
        reason: { type: string, nullable: true }
        decision: { allOf: [{ $ref: '#/components/schemas/ApprovalDecisionKind' }], nullable: true }
        decided_by: { type: object, additionalProperties: true, nullable: true }
        requested_at: { type: string, format: date-time }
        decided_at: { type: string, format: date-time, nullable: true }
        expires_at: { type: string, format: date-time }
        paged_at_50_percent: { type: boolean }
        superseded_interaction_id: { type: string, nullable: true }

    ApprovalPage:
      type: object
      required: [items]
      properties:
        items:
          type: array
          items: { $ref: '#/components/schemas/Approval' }
        next_cursor: { type: string, nullable: true }
        total_estimate: { type: integer, nullable: true }

    ApprovalDecision:
      type: object
      required: [decision, decided_by]
      properties:
        decision: { $ref: '#/components/schemas/ApprovalDecisionKind' }
        decided_by:
          type: object
          required: [actor, role]
          properties:
            actor: { type: string, description: "user id, agent name, or 'board'" }
            role: { type: string, enum: [pm, cto, ceo, qa, security, devops, docs, engineer, board] }
        reason: { type: string }

    # ---------- Interactions ----------------------------------------------
    CreateInteractionRequest:
      type: object
      required: [kind, prompt]
      properties:
        kind: { type: string, enum: [request_confirmation, suggest_tasks, ask_user_questions] }
        schema_version: { type: integer, default: 1 }
        prompt: { type: string, description: "Full prompt text. Per the interaction schema, options/buttons are baked into the prompt text." }
        allow_decline_reason: { type: boolean, default: true }
        supersede_on_user_comment: { type: boolean, default: false }
        run_id: { type: string, format: uuid, nullable: true }
        issue_id: { type: string, format: uuid, nullable: true }
        questions:
          type: array
          description: "When kind=ask_user_questions. Each question uses selectionMode, not type."
          items:
            type: object
            required: [id, prompt, options, selection_mode]
            properties:
              id: { type: string }
              prompt: { type: string }
              header: { type: string, description: "Short chip label (max 12 chars)." }
              options:
                type: array
                minItems: 2
                maxItems: 4
                items:
                  type: object
                  required: [label, description]
                  properties:
