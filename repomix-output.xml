def test_queue() -> None
⋮----
q = burst.AdapterQueue(max_depth=3)
_assert(q.depth == 0, "empty depth=0")                    # T-101
_assert(q.is_empty, "is_empty true initial")              # T-102
_assert(q.peek_lane() is None, "peek empty None")         # T-103
