    account: "111122223333"                       # Acme's prod AWS account
    role_ref: "arn:aws:iam::111122223333:role/ForgeBrokeredDeployRole"
    expected_issuer: "https://identity-broker.fora.local/auth"
    expected_audience: "customer-cloud-broker"
</file>

<file path="tenants/acme/policy.yaml">
# tenants/acme/policy.yaml
#
# Acme's tenant policy (FORA-125 / 0.7.3).
#
# Narrows the platform default for tenant acme. The platform default is
# deny; everything here is a *positive* grant. A grant that names a role
# or MCP that the platform registry does not know about is rejected at
# load time — the tenant cannot widen beyond the platform default.
#
# Acceptance scenarios for FORA-125:
#   - developer + aws-deploy succeeds here (mcp_grants.developer['aws-deploy'] == true).
#   - developer + aws-billing is denied (no grant; also aws-billing is not
#     in developer's role mcps list, so it would be unbound_mcp).

version: 1
description: >
  Acme Corp tenant policy. Grants developers the deploy MCP for
  acme-prod only; denies billing for everyone; narrows ba-agent to
  read-only on slack.

mcp_grants:
  developer:
    aws-deploy: true        # explicit grant satisfies the FORA-125 acceptance bar
  deploy-agent:
    aws-deploy: true
    customer-cloud-broker: true
  security-engineer:
    aws-deploy: true
  audit:
    aws-billing: true       # audit must see billing for compliance review

deny:
  - aws-billing            # nobody else can read billing; audit's grant above overrides only for the audit role

scope_overrides:
  ba-agent:
    - read                  # drop nothing; ba-agent was already read-only
</file>

<file path="tenants/dogfood/workflow.yaml">
# FORA tenant workflow configuration — dogfood (FORA-200.3 / FORA-405)
#
# This is the first tenant-level workflow config. It declares
# the Paperclip ↔ Jira stage transition table for the dogfood
# tenant (FORA's own internal usage, against the FORA Jira
# project).
#
# **Inheritance:** when this file is present, the resolver
# reads it as a positive override on top of the closed-set
# default in `apps/jira-adapter/src/workflow-mapping.ts`
# (the `DEFAULT_STAGE_TRANSITIONS` const). When absent for a
# given status, the default wins. A per-process env var
# (`sync.stage.<status>.v1.jira_status`) wins over BOTH this
# YAML and the default — see `stageOverrideEnvVar()` in
# `apps/jira-adapter/src/workflow-mapping.ts`.
#
# **Schema:** every key under `transitions` MUST be one of the
# six v0.1 primary Paperclip statuses from
# `PaperclipStatus` (`approved`, `in_progress`, `in_review`,
# `blocked`, `done`, `cancelled`). The value is the literal
# Jira-side transition name as the customer's Jira workflow
# exposes it (e.g. "Approved", "In Progress"). Case matters —
# Jira Cloud's transition lookup is case-sensitive.
#
# **Audit:** every resolution is reflected in the
# `sync.source.stage.ok` / `sync.target.stage.ok` audit
# event's `metadata.transition_name` field, so an operator
# can verify post-hoc which row of this YAML was used for a
# given transition.
#
# Reference: FORA-200 plan §3 "Status-transition config" +
# §2 AC#3. CTO-approved default `approved → "Approved"`
# (comment `8abb9965-…`).

version: 1
# Free-form human-readable description; surfaces in the
# `tenants/dogfood/workflow.yaml` row of the FORA runbooks
# index. Update when the mapping changes shape.
description: >
  FORA dogfood tenant — Paperclip ↔ Jira status transition table.
  Mirrors the Jira Software default workflow's display names
  (Approved / In Progress / In Review / Blocked / Done /
  Cancelled). Inherits defaults from
  apps/jira-adapter/src/workflow-mapping.ts when this file
  does not list a status.

transitions:
  # CTO-approved default (comment 8abb9965-…). The dogfood
  # project's Jira workflow has the "Approved" transition
  # between "In Review" and "Done".
  approved: "Approved"

  # Paperclip "in_progress" maps to Jira "In Progress" — the
  # most common transition the adapter drives. Listed
  # explicitly here so a future rename on the Jira side
  # surfaces as a YAML diff in PR review (rather than a
  # silent fallthrough to the default).
  in_progress: "In Progress"

  # Paperclip "in_review" maps to Jira "In Review". Distinct
  # from "in_progress" — Paperclip uses "in_review" for the
  # human review gate, Jira uses the same display name.
  in_review: "In Review"

  # Paperclip "blocked" maps to Jira "Blocked". Note: this
  # is the Jira *transition* name, not the Jira *status*
  # name — Jira Cloud treats them as the same string in the
  # default workflow, but a customer with a custom workflow
  # could have "Blocked" as a status with a different
  # transition name. The adapter calls
  # `JiraStageClient.transitionIssue({ transitionName })`
  # which resolves the name to the project-local id.
  blocked: "Blocked"

  # Paperclip "done" maps to Jira "Done". The terminal
  # state on both sides.
  done: "Done"

  # Paperclip "cancelled" maps to Jira "Cancelled". The
  # other terminal state. Note: the FORA-200 v0.1 day-one
  # scope does NOT drive the Jira "Done" → "Cancelled"
  # transition automatically (that's a Jira-side workflow
  # concern); the adapter fires the transition when
  # Paperclip side transitions to "cancelled".
  cancelled: "Cancelled"
</file>

