  /** Absolute path to the file. */
  file: string;
  /** Path relative to the allow-list root, e.g. `migrations/0001_tenants.sql`. */
  relPath: string;
  /** 1-indexed line number. */
  line: number;
  /** The full line that triggered the finding. */
  text: string;
}
