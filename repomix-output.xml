<file path="forge/sync-plane/tenants/acme/ownership.yaml">
# ADR-0010 §4 field-ownership table — tenant override file.
# This sample tenant ("acme") demonstrates the override surface; the
# default table from `src/ownership.ts` is applied first, then these rules
# replace matching field paths.

version: 1

# Per-tenant precedence for state-machine fields (ADR-0010 §4 last paragraph).
statePrecedence:
  - paperclip
  - jira
  - github
  - clickup

fields:
  # Tenant has chosen Jira as the canonical owner of `issue.summary`.
  issue.summary:
    mode: single
    owner: jira
    mirrorPolicy: read_only_on_remote

  # Tier-2 with a restricted writer set: only Paperclip and Jira may write
  # to the issue description; GitHub + ClickUp are read-only for this field.
  issue.body:
    mode: tier2
    writers:
      - paperclip
      - jira

  # The workflow status is owned by whichever platform created the issue.
  issue.status:
    mode: creator
    fallback: paperclip
    mirrorPolicy: translated_mirror_state
</file>

