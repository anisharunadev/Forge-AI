<file path="mcp-servers/arch-analyzer/src/parsers/java.ts">
/**
 * Java parser. Detects:
 *   - Single-line: `import a.b.C;`
 *   - Static imports: `import static a.b.C.method;`
 *   - Wildcards: `import a.b.*;`     (edge with raw = "a.b.*")
 *
