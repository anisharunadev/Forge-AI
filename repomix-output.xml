<file path="config/agent-iam/roles.yaml">
# config/agent-iam/roles.yaml
#
# Static role registry for FORA sub-agents (FORA-125 / 0.7.3).
#
# Every sub-agent type has exactly one role. The role names the MCPs that
# role is *eligible* to call and the scopes the role may claim on each
# call. The platform default is "unbound" — a new MCP must be added to at
# least one role's `mcps:` list in the same PR that introduces it, or
# CI fails (see tools/lint-unbound-mcps.mjs).
#
# Per ADR-0003 §5.1, this file is the *platform* surface. A tenant may
# *narrow* these bindings in `tenants/{tenant_id}/policy.yaml` but never
# widen them. A tenant cannot add an MCP to a role that the platform
# registry does not name — the loader rejects such policies.
#
# Schema: config/agent-iam/roles.schema.json
# Loader: apps/identity-broker/src/iam.ts (`loadRoleRegistry`)

version: 1

# MCPs that exist in the platform. The CI lint cross-references this list
# against `roles[].mcps` and fails the build if any MCP here has no
# binding to any role. Adding an MCP without a role binding is a bug.
mcps:
  - jira
  - zendesk
  - slack
  - confluence
  - github
  - sonarqube
  - figma
  - aws-deploy
  - aws-billing
  - argo
  - secrets-mcp
  - customer-cloud-broker
  - arch-analyzer
  - memory
  - cost
  - evaluation
  - audit

# MCP scope vocabulary. The set of allowed scope strings is a closed
# world; the loader rejects any role that claims a scope not in this list.
# The format is `<verb>` or `<verb>:<noun>` to allow fine-grained scopes
# on a single MCP (e.g. `write:deploy-request` on `argo`).
scopes:
  - read
  - write
  - write:code
  - write:findings
  - write:deploy-request
  - read:billing
  - read:audit-log
  - write:audit-log
  - read:cost
  - write:cost
  - read:eval
  - write:eval
  - read:memory
  - write:memory
  - mcp:read
  - mcp:write

# Role definitions. Each role is the complete capability surface for one
# sub-agent type. A role's `mcps` are the only MCPs the broker will
# forward a `ToolCall` for; `scopes` are the only scopes the broker will
# accept in `scopes_used`.
#
# `deny_scopes` (optional) is an explicit deny list for scopes that the
# MCP technically exposes but the role must never claim. v1 ships the
# high-risk ones here.
roles:
  ba-agent:
    description: >
      Business Analyst. Reads requirements and customer context from
      ticket trackers and documentation; never writes code or deploys.
    mcps: [jira, zendesk, slack, confluence, figma]
    scopes: [read]
    deny_scopes: []

  architect:
    description: >
      Solution / technical architect. Reads the codebase via arch-analyzer
      and writes ADRs / design docs to confluence; reads figma for
      design intent.
    mcps: [arch-analyzer, confluence, jira, github, figma]
    scopes: [read, write]
    deny_scopes: [write:deploy-request, write:findings]

  developer:
    description: >
      Coding agent. Reads and writes code via GitHub; cannot deploy
      unless the tenant policy explicitly grants `developer: aws-deploy`
      (the FORA-125 acceptance bar).
    mcps: [github, jira, arch-analyzer, secrets-mcp, memory, figma, aws-deploy]
    scopes: [read, write:code, read:memory, write:memory]
    deny_scopes: [write:deploy-request, read:billing, write:findings]

  security-engineer:
    description: >
      Security reviewer. Reads source via GitHub, findings via SonarQube,
      and writes security findings. Can read secrets refs but never raw
      values. May invoke aws-deploy via the customer-cloud-broker when
      the tenant grants it (read-only inspection).

      FORA-290 allow-list (read-only MCP tools):
        - confluence  (list_pages, get_page, search) — threat-model docs
        - slack       (list_channels, list_threads, get_thread, search_messages) — incident channel review
        - aws-deploy  (list_stacks, get_stack, list_stack_resources, get_resource, list_change_sets, get_change_set, describe_change_set) — broker-mediated IAM/CloudTrail/SecurityHub read
        - sonarqube   (list_projects, get_project, search_components, get_component_measures, list_issues, get_issue, get_quality_gate, webhooks_get) — broker-mediated hotspot read
    mcps: [github, sonarqube, secrets-mcp, confluence, slack, arch-analyzer, aws-billing, aws-deploy]
    scopes: [read, mcp:read, write:findings, read:billing]
    deny_scopes: [write:code, write:deploy-request, mcp:write]

  deploy-agent:
    description: >
      DevOps / release agent. Reads code from GitHub; deploys via the
      customer-cloud-broker (which holds the OIDC federation trust, see
      ADR-0003 §6) or directly via aws-deploy when the tenant grants
      it. Cannot read billing.
    mcps: [github, argo, customer-cloud-broker, secrets-mcp, aws-deploy]
    scopes: [read, write:deploy-request]
    deny_scopes: [write:code, write:findings, read:billing]

  audit:
    description: >
      Cross-cutting audit agent. Reads the audit log; writes audit
      annotations only. May read aws-billing when a tenant explicitly
      grants it (for compliance review).
    mcps: [audit, confluence, arch-analyzer, aws-billing]
    scopes: [read:audit-log, write:audit-log, read]
    deny_scopes: [write:code, write:deploy-request, write:findings]

  cost:
    description: >
      Cross-cutting cost agent. Reads the cost / token-usage streams;
      writes budget annotations.
    mcps: [cost, confluence, arch-analyzer]
    scopes: [read:cost, write:cost, read]
    deny_scopes: [write:code, write:deploy-request, write:findings, read:billing]

  evaluation:
    description: >
      Cross-cutting evaluation agent. Reads eval signals; writes eval
      annotations.
    mcps: [evaluation, arch-analyzer, confluence]
    scopes: [read:eval, write:eval, read]
    deny_scopes: [write:code, write:deploy-request, write:findings, read:billing]

  memory:
    description: >
      Cross-cutting memory agent. Reads and writes the Knowledge Layer.
      Never reads billing, deploy, or audit-log content.
    mcps: [memory, arch-analyzer, confluence]
    scopes: [read:memory, write:memory, read]
    deny_scopes: [write:code, write:deploy-request, write:findings, read:billing]
</file>

<file path="config/customer-cloud-broker/deny_list.yaml">
# Global deny-list for the customer-cloud-broker.
#
# Every entry is `(cloud, action_regex)`. The broker checks the action
# against the deny-list *before* it ever contacts the cloud — the
# federation token is never minted, the action is never executed.
# Failures are logged as `cloud.brokered` audit events with
# `response_code = deny_listed`.
#
# Format: `actions` is a list of `{ cloud, action }` pairs where
# `action` is a regex anchored to the full action string.
# Match means deny; partial means deny too (regex is full-match
# with start/end anchors applied at check time, see `src/deny-list.ts`).
#
# This list is the second line of defence after IAM permissions on the
# customer's role. The customer might grant overly broad permissions; the
# deny-list catches actions the platform refuses to perform *regardless*
# of tenant policy. Adding an entry is a one-line PR; removing one needs
# CEO + Security sign-off (per ADR-0003 §6.3).

version: 1

actions:
  # ---------------------------------------------------------------------------
  # AWS — the highest-volume cloud. `iam:*` and `sts:*` are universally
  # dangerous: a misconfigured grant could delete a customer's IAM users.
  # ---------------------------------------------------------------------------
  - cloud: aws
    action: "^iam:DeleteUser$"
  - cloud: aws
    action: "^iam:CreateUser$"
  - cloud: aws
    action: "^iam:CreateAccessKey$"
  - cloud: aws
    action: "^iam:DeleteAccessKey$"
  - cloud: aws
    action: "^iam:AttachUserPolicy$"
  - cloud: aws
    action: "^iam:DetachUserPolicy$"
  - cloud: aws
    action: "^iam:PutUserPolicy$"
  - cloud: aws
    action: "^iam:DeleteUserPolicy$"
  - cloud: aws
    action: "^iam:CreateRole$"
  - cloud: aws
    action: "^iam:DeleteRole$"
  - cloud: aws
    action: "^iam:PassRole$"          # privilege escalation primitive
  - cloud: aws
    action: "^iam:AssumeRole$"        # broker is the only legitimate assumer
  - cloud: aws
    action: "^sts:AssumeRole$"
  - cloud: aws
    action: "^account:DisableRegion$"
  - cloud: aws
    action: "^account:CloseAccount$"

  # ---------------------------------------------------------------------------
  # Azure — analogous dangerous operations. ARM roles and assignments are
  # the privilege-escalation primitive; deny writes to them.
  # ---------------------------------------------------------------------------
  - cloud: azure
    action: "^authorization/roleAssignments/write$"
  - cloud: azure
    action: "^authorization/roleDefinitions/write$"
  - cloud: azure
    action: "^authorization/roleDefinitions/delete$"
  - cloud: azure
    action: "^Microsoft.Authorization/roleAssignments/write$"
  - cloud: azure
    action: "^Microsoft.Authorization/roleDefinitions/write$"

  # ---------------------------------------------------------------------------
  # GCP — IAM bindings and service account key creation.
  # ---------------------------------------------------------------------------
  - cloud: gcp
    action: "^iam.serviceAccounts.actAs$"
  - cloud: gcp
    action: "^iam.serviceAccountKeys.create$"
  - cloud: gcp
    action: "^iam.serviceAccounts.create$"
  - cloud: gcp
    action: "^iam.serviceAccounts.delete$"
  - cloud: gcp
    action: "^resourcemanager.projects.setIamPolicy$"

  # ---------------------------------------------------------------------------
  # SonarQube (FORA-321) — read-only mandate from FORA-290. The
  # `perform()` dispatcher is GET-only, so the only defence here is the
  # action string itself (which the broker matches before the
  # dispatcher is reached). Anything that looks like a write path is
  # denied by name; the positive allowlist in
  # `src/adapters/sonarqube.ts::SERVICE_OPS` is the source of truth.
  # ---------------------------------------------------------------------------
  - cloud: sonarqube
    action: "^projects\\.create$"
  - cloud: sonarqube
    action: "^projects\\.delete$"
  - cloud: sonarqube
    action: "^projects\\.update$"
  - cloud: sonarqube
    action: "^issues\\.transition$"
  - cloud: sonarqube
    action: "^issues\\.assign$"
  - cloud: sonarqube
    action: "^issues\\.add_comment$"
  - cloud: sonarqube
    action: "^qualitygates\\.create$"
  - cloud: sonarqube
    action: "^qualitygates\\.delete$"
  - cloud: sonarqube
    action: "^qualitygates\\.update$"
  - cloud: sonarqube
    action: "^webhooks\\.create$"
  - cloud: sonarqube
    action: "^webhooks\\.delete$"
  - cloud: sonarqube
    action: "^webhooks\\.update$"
  - cloud: sonarqube
    action: "^user_tokens\\.generate$"
  - cloud: sonarqube
    action: "^user_tokens\\.revoke$"
  - cloud: sonarqube
    action: "^user_tokens\\.search$"
  - cloud: sonarqube
    action: "^settings\\.set$"
  - cloud: sonarqube
    action: "^permissions\\.(add|remove)_(user|group)$"
</file>

