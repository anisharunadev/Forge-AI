# FORA local dev environment (FORA-371)
#
# Copy to `.env` and edit the values you need to override.
# `scripts/dev-up.sh` loads this file before booting the stack.
#
# Never commit `.env` — it's in `.gitignore` and any secrets it
# carries are dev-only. Production uses IAM + Secrets Manager.

# ---------------------------------------------------------------------------
# Postgres (apps/orchestrator, packages/db-migrator, packages/db-pool)
# ---------------------------------------------------------------------------
POSTGRES_USER=fora
POSTGRES_PASSWORD=fora
POSTGRES_DB=fora
POSTGRES_PORT=5432
# `pg` connection string the apps actually read.
FORA_DATABASE_URL=postgres://fora:fora@localhost:5432/fora
FORA_TENANT_POOL=strict

# ---------------------------------------------------------------------------
# Redis (packages/cache-broker, packages/session-tokens,
#         packages/sync-plane-ratelimit)
# ---------------------------------------------------------------------------
REDIS_PORT=6379
# Apps read REDIS_URL — not FORA_REDIS_URL — so the convention
# matches Redis client libraries and is recognised by tooling.
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# LocalStack (packages/object-store, apps/customer-cloud-broker,
#             apps/identity-broker — S3, IAM, STS, Secrets Manager)
# ---------------------------------------------------------------------------
LOCALSTACK_PORT=4566
AWS_REGION=us-east-1
# LocalStack's baked-in dummy creds (image default). The @aws-sdk
# clients accept anything; in production these come from IAM.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# LocalStack only — production AWS ignores AWS_ENDPOINT_URL.
AWS_ENDPOINT_URL=http://localhost:4566
OBJECT_STORE_BUCKET=fora-dev-bucket

# ---------------------------------------------------------------------------
# Anthropic (Master Orchestrator + every Claude-backed sub-agent)
# ---------------------------------------------------------------------------
# You MUST set this to a real key. Get one from
# https://console.anthropic.com/. Without it the Claude-backed
# agents fail at first token. The dev quickstart defaults to
# Haiku 4.5 to keep the per-run cost under a cent.
ANTHROPIC_API_KEY=sk-ant-replace-me

# ---------------------------------------------------------------------------
# Agent Runtime (apps/agent-runtime — dev HTTP shim on :4001)
# ---------------------------------------------------------------------------
# The runtime is a library; the `dev` script wraps it in a tiny
# Fastify server that serves /health. Override only if you have a
# port clash.
FORA_RUNTIME_PORT=4001
FORA_RUNTIME_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Master Orchestrator (apps/orchestrator — :4000)
# ---------------------------------------------------------------------------
FORA_ORCHESTRATOR_PORT=4000
FORA_ORCHESTRATOR_HOST=0.0.0.0
FORA_DEFAULT_COST_CEILING_USD=100.00
FORA_ORCHESTRATOR_LOG_LEVEL=info
FORA_ENV=dev
# NATS is the production event bus; the local stack does not boot
# NATS, so the orchestrator falls back to the in-process bus. To
# wire a real NATS container, set FORA_NATS_URL to its address and
# the orchestrator will connect (FORA-136 — the bus package — owns
# the integration). Leave unset in dev to use the log-only stub.
# FORA_NATS_URL=nats://localhost:4222

# ---------------------------------------------------------------------------
# Forge AI Console (apps/forge — :3000, FORA-374)
# ---------------------------------------------------------------------------
# Next.js 15 dev server. `pnpm --filter @fora/forge dev` picks these up.
# The console reads the orchestrator REST API from FORA_FORGE_API_URL;
# the same URL is exposed to the browser as NEXT_PUBLIC_FORGE_API_URL.
# Override only if you have a port clash with another tool.
FORA_FORGE_PORT=3000
FORA_FORGE_HOST=0.0.0.0
FORA_FORGE_API_URL=http://localhost:4000
NEXT_PUBLIC_FORGE_API_URL=http://localhost:4000
# Demo run id the persona dashboards render when no runs are indexed yet
# (the orchestrator 0.1.x does not expose GET /v1/runs). Set to an empty
# string to render the "no runs visible" empty state.
FORA_SEED_RUN_ID=demo-run-001

# ---------------------------------------------------------------------------
# Customer Cloud Broker (apps/customer-cloud-broker — :4003)
# ---------------------------------------------------------------------------
FORA_CCB_LISTEN_HOST=0.0.0.0
FORA_CCB_LISTEN_PORT=4003
# The broker is OIDC-issued; the dev `start.ts` accepts any URL
# here but `buildServer` will refuse to bind without a valid
# `FORA_CCB_PUBLIC_URL` so this is the URL the orchestrator uses
# to reach the broker.
FORA_CCB_PUBLIC_URL=http://localhost:4003
FORA_CCB_ISSUER=http://localhost:4003
FORA_CCB_AUDIENCE=customer-cloud-broker
FORA_CCB_BROKER_AUDIENCE=customer-cloud-broker
FORA_CCB_DENY_LIST_PATH=config/customer-cloud-broker/deny_list.yaml
FORA_CCB_TENANT_TRUST_ROOT=tenants
FORA_CCB_AUDIT_LOG_PATH=.fora/audit/customer-cloud-broker.jsonl
FORA_CCB_ENV=development
# Canary probe signer (FORA-126.4). The dev key is a 32-byte
# placeholder; production loads from Secrets Manager.
FORA_CCB_PROBE_SIGNING_KEY=dev-probe-signing-key-change-me-32bytes!
FORA_CCB_PROBE_INTERVAL_MS=300000
# SonarQube adapter token (FORA-321). Leave blank in dev unless
# you have a real SonarQube.
SONARQUBE_BROKER_TOKEN=

# ---------------------------------------------------------------------------
# Session tokens (packages/session-tokens — HS256 signing key)
# ---------------------------------------------------------------------------
# MUST be at least 32 bytes for HS256. `dev` is a placeholder;
# production uses the identity-broker's KMS-wrapped key.
SESSION_TOKENS_SIGNING_KEY=dev-only-session-tokens-signing-key-32+bytes

# ---------------------------------------------------------------------------
# Audit (packages/cache-broker/audit, packages/db-migrator)
# ---------------------------------------------------------------------------
# 0 = disable file-sink audit; 1 = enable (default in dev).
FORA_AUDIT_ENABLED=1
FORA_AUDIT_LOG=.fora/audit/tenancy-denied.jsonl

# ---------------------------------------------------------------------------
# Tenant seed — the demo tenant the AC asserts exists in Postgres.
# ---------------------------------------------------------------------------
# The first time the migrator runs it seeds exactly one tenant:
# `acme-corp` with policy "public-preview" so the dashboard has
# something to render. The seed is idempotent — re-running is a
# no-op.
FORA_SEED_TENANT_ID=acme-corp
FORA_SEED_TENANT_NAME="Acme Corp (Dev Demo)"
FORA_SEED_TENANT_POLICY=public-preview

# ===========================================================================
# Forge AI v2.0 — new env vars (PostgreSQL 17 + AGE + pgvector, Keycloak,
#                  LiteLLM, floci). The FORA_* block above is retained for
#                  reference during the v1→v2 migration; production v2.0
#                  deployments read the FORGE_* and *_PORT vars below.
# ===========================================================================

# ---------------------------------------------------------------------------
# Postgres 17 (ADR-002)
# ---------------------------------------------------------------------------
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB are also read by
# docker-compose.yml directly; the duplicates below let the backend
# container compose its own DATABASE_URL.
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge
POSTGRES_PORT=5432
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge

# ---------------------------------------------------------------------------
# Redis 7
# ---------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Backend (FastAPI :8000)
# ---------------------------------------------------------------------------
BACKEND_PORT=8000
ENV=development

# ---------------------------------------------------------------------------
# Frontend (Next.js 15 :3000)
# ---------------------------------------------------------------------------
FORGE_UI_PORT=3000
# Backend the browser hits. In dev (this compose) it is the
# localhost-mapped port; in staging/prod it is the public URL.
FORGE_API_BASE_URL=http://localhost:8000/api/v1
FORGE_WS_BASE_URL=ws://localhost:8000/ws

# ---------------------------------------------------------------------------
# Keycloak 26+ (OIDC + SAML)
# ---------------------------------------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Issuer URL the backend uses to fetch JWKS. NO trailing slash.
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=forge
# Frontend reads this on the client to build the redirect URL.
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# step-53 Zone 1 — secret for the confidential `forge-backend` client
# defined in infra/keycloak/realm-forge.json. The realm import resolves
# ${FORGE_BACKEND_CLIENT_SECRET} on first boot. Generate with:
#   openssl rand -hex 32
FORGE_BACKEND_CLIENT_SECRET=forge-backend-dev-secret-change-in-prod

# step-53 Zone 2/3 — HMAC secret the backend uses to sign the Forge
# JWTs it issues to the SPA. HS256 in dev (RS256 via JWKS in prod per
# core/config.py). MUST be at least 32 chars; rotate via the
# `jwt_secret` setting on next deploy.
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-long

# ---------------------------------------------------------------------------
# LiteLLM Proxy (DL-025) — sole LLM access path
# ---------------------------------------------------------------------------
LITELLM_PORT=4000
# DL-025: the master key gates every /v1/* request through the proxy.
# MUST be set in any non-dev environment. Generate with:
#   openssl rand -hex 32
LITELLM_MASTER_KEY=sk-litellm-dev-replace-me
LITELLM_PROXY_URL=http://localhost:4000
# Bearer token the backend uses for LiteLLM (DL-025).
LITELLM_API_KEY=sk-litellm-dev-replace-me
# Upstream provider keys (read by infra/litellm/config.yaml via os.environ).
OPENAI_API_KEY=sk-openai-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me

# ---------------------------------------------------------------------------
# Local AWS Emulation (floci) — dev-only multi-service stand-in
# ---------------------------------------------------------------------------
# floci is the open-source LocalStack Community successor
# (https://github.com/floci-io/floci). 90 MB image, 13 MiB RAM,
# ~24 ms startup, emulates 58 AWS services (S3, SQS, SNS, Lambda,
# RDS, DynamoDB, Secrets Manager, IAM, STS, ...). It accepts any
# non-empty AWS credentials, so the test/test defaults below are
# fine. ADR-001: production uses real AWS, not floci.
FLOCI_PORT=4566
FLOCI_DEFAULT_REGION=us-east-1
FLOCI_DEFAULT_ACCOUNT_ID=000000000000
FLOCI_STORAGE_MODE=persistent
# Browser-accessible URL (for presigned GETs).
FLOCI_PUBLIC_URL=http://localhost:4566
# Endpoint the AWS SDKs target inside the docker network.
FLOCI_URL=http://localhost:4566
OBJECT_STORE_BUCKET=forge-dev-bucket
# AWS region sent in SigV4 signatures. ADR-001: production uses
# real AWS, not floci.
AWS_REGION=us-east-1
# Dummy creds for local floci only. Production uses IAM roles
# (no static keys).
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# Points the AWS SDKs at floci in dev. The SDKs ignore this env
# var when unset, which is the production behaviour. boto3 and the
# JS SDK both honour AWS_ENDPOINT_URL automatically.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# S3 Buckets — auto-created by scripts/floci-init/01-create-buckets.sh
#               on the first floci boot.
# ---------------------------------------------------------------------------
S3_BUCKET_ARTIFACTS=forge-artifacts
S3_BUCKET_TERMINAL_EXPORTS=forge-terminal-exports
S3_BUCKET_DOCS=forge-docs

# ---------------------------------------------------------------------------
# Docs Site (docs-site/ — Astro 5 + Starlight, served on :4321)
# ---------------------------------------------------------------------------
DOCS_SITE_PORT=4321

# ===========================================================================
# Phase 7 SC-7.7 — full Settings surface coverage.
# Each Settings field in backend/app/core/config.py has a row here so
# scripts/check-env-example.sh exits 0. Defaults shown in comments.
# ===========================================================================

# ---------------------------------------------------------------------------
# App / server
# ---------------------------------------------------------------------------
APP_NAME=forge-backend
APP_VERSION=0.2.0
# ENVIRONMENT: development | staging | production | test
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
# Port the FastAPI backend binds (mirrors BACKEND_PORT for compose).
PORT=8000
# JSON list of allowed CORS origins.
CORS_ORIGINS=["http://localhost:3000"]

# ---------------------------------------------------------------------------
# Postgres / Redis (settings-layer aliases)
# ---------------------------------------------------------------------------
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
REDIS_EVENT_CHANNEL_PREFIX=forge:events:

# ---------------------------------------------------------------------------
# LiteLLM Proxy (settings layer)
# ---------------------------------------------------------------------------
LITELLM_DEFAULT_MODEL=gpt-4o-mini
# APPROVAL_TIMEOUT_OVERRIDES is a dict[str, int] (model -> seconds).
APPROVAL_TIMEOUT_OVERRIDES={}
APPROVAL_TIMEOUT_HOURS=24
LITELLM_ADMIN_KEY=sk-litellm-admin-replace-me
LITELLM_KEY_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# AWS Secrets Manager
# ---------------------------------------------------------------------------
AWS_SECRETS_MANAGER_PREFIX=forge/tenants/
AWS_SECRETS_MANAGER_KMS_KEY_ID=

# ---------------------------------------------------------------------------
# LiteLLM budgets / guardrails
# ---------------------------------------------------------------------------
LITELLM_BUDGET_DEFAULT_USD=500.00
LITELLM_BUDGET_DEFAULT_PERIOD=monthly
LITELLM_HEALTH_CHECK_INTERVAL_SECONDS=30
LITELLM_USAGE_CACHE_TTL_SECONDS=60
LITELLM_INTEGRATION_ENABLED=true
LITELLM_AUTO_PROVISION_KEYS=true
LITELLM_BUDGET_HARD_LIMIT=true
LITELLM_GUARDRAIL_PII_DEFAULT=true
LITELLM_GUARDRAIL_CONTENT_DEFAULT=true
LITELLM_GUARDRAIL_INJECTION_DEFAULT=true

# ---------------------------------------------------------------------------
# Keycloak / JWT (settings layer)
# ---------------------------------------------------------------------------
KEYCLOAK_CLIENT_ID=forge-backend
KEYCLOAK_AUDIENCE=forge-backend
# JWT_SECRET is set above; JWT_SECRET_PREVIOUS is used by the rotation
# overlap window (Phase 7 SC-7.2). Leave empty unless rotating.
JWT_SECRET_PREVIOUS=
# JWT_ALGORITHM: HS256 (dev) | RS256 (prod via JWKS)
JWT_ALGORITHM=HS256
JWT_AUDIENCE=
JWT_ISSUER=

# ---------------------------------------------------------------------------
# OpenTelemetry
# ---------------------------------------------------------------------------
OTLP_ENDPOINT=
OTEL_SERVICE_NAME=forge-backend
OTEL_EXPORTER_OTLP_INSECURE=true

# ---------------------------------------------------------------------------
# WebSocket / Terminal Center
# ---------------------------------------------------------------------------
WS_MAX_MESSAGE_BYTES=65536
WS_IDLE_TIMEOUT_SECONDS=300
TERMINAL_WORKSPACE_ROOT=/var/forge/workspaces

# ---------------------------------------------------------------------------
# Connector freshness
# ---------------------------------------------------------------------------
CONNECTOR_DEFAULT_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# Cost / budget guards
# ---------------------------------------------------------------------------
COST_CURRENCY=USD
MERGE_GATE_PER_COMMIT_COST_CAP_USD=1.0
RUN_BUDGET_CAP_USD=50.00
# RUN_BUDGET_CAP_OVERRIDES is dict[str, float] (tenant_id -> USD cap).
RUN_BUDGET_CAP_OVERRIDES={}

# ---------------------------------------------------------------------------
# Forge header / discovery
# ---------------------------------------------------------------------------
FORGE_HEALTH_CACHE_TTL_SECONDS=60
FORGE_TENANT_HEADER=X-Forge-Tenant
FORGE_RUN_HEADER=X-Forge-Run-Id
FORGE_ROUTE_DISCOVERY_ENABLED=true

# ---------------------------------------------------------------------------
# GitHub webhooks
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Dev auth bypass
# ---------------------------------------------------------------------------
# DEV_AUTH_BYPASS must be false in any non-development environment.
# Guarded by `_dev_bypass_only_in_dev` validator in Settings.
DEV_AUTH_BYPASS=false

# ---------------------------------------------------------------------------
# Copilot
# ---------------------------------------------------------------------------
COPILOT_ENABLED=true
COPILOT_DEFAULT_BUDGET_USD=5.00
COPILOT_TOOL_CALL_MAX=20
COPILOT_RATE_LIMIT_PER_MIN=30
COPILOT_WELCOME_ENABLED=true

# ---------------------------------------------------------------------------
# Phase 6 degradation queue
# ---------------------------------------------------------------------------
DEGRADATION_QUEUE_MAX=128
DEGRADATION_QUEUE_TTL_SECONDS=600

# ---------------------------------------------------------------------------
# Phase 6 rate limiting
# ---------------------------------------------------------------------------
CHAT_RATE_LIMIT_PER_MIN=60
RATE_LIMIT_REDIS_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Phase 6 tenant budget enforcement v2
# ---------------------------------------------------------------------------
TENANT_BUDGET_ENFORCEMENT_V2_DEFAULT=true

# ---------------------------------------------------------------------------
# LLM keys (placeholders allowed in dev only)
# ---------------------------------------------------------------------------
ALLOW_PLACEHOLDER_LLM_KEYS=true
ANTHROPIC_API_KEY=sk-ant-replace-me
OPENAI_API_KEY=sk-openai-replace-me
