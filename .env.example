# FORA local dev environment (FORA-371)
#
# Copy to `.env` and edit the values you need to override.
# `scripts/dev-up.sh` loads this file before booting the stack.
#
# Never commit `.env` — it's in `.gitignore` and any secrets it
# carries are dev-only. Production uses IAM + Secrets Manager.

# ---------------------------------------------------------------------------
# Postgres (apps/orchestrator, packages/db-migrator, packages/db-pool)
# ---------------------------------------------------------------------------
POSTGRES_USER=fora
POSTGRES_PASSWORD=fora
POSTGRES_DB=fora
POSTGRES_PORT=5432
# `pg` connection string the apps actually read.
FORA_DATABASE_URL=postgres://fora:fora@localhost:5432/fora
FORA_TENANT_POOL=strict

# ---------------------------------------------------------------------------
# Redis (packages/cache-broker, packages/session-tokens,
#         packages/sync-plane-ratelimit)
# ---------------------------------------------------------------------------
REDIS_PORT=6379
# Apps read REDIS_URL — not FORA_REDIS_URL — so the convention
# matches Redis client libraries and is recognised by tooling.
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# LocalStack (packages/object-store, apps/customer-cloud-broker,
#             apps/identity-broker — S3, IAM, STS, Secrets Manager)
# ---------------------------------------------------------------------------
LOCALSTACK_PORT=4566
AWS_REGION=us-east-1
# LocalStack's baked-in dummy creds (image default). The @aws-sdk
# clients accept anything; in production these come from IAM.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
# LocalStack only — production AWS ignores AWS_ENDPOINT_URL.
AWS_ENDPOINT_URL=http://localhost:4566
OBJECT_STORE_BUCKET=fora-dev-bucket

# ---------------------------------------------------------------------------
# Anthropic (Master Orchestrator + every Claude-backed sub-agent)
# ---------------------------------------------------------------------------
# You MUST set this to a real key. Get one from
# https://console.anthropic.com/. Without it the Claude-backed
# agents fail at first token. The dev quickstart defaults to
# Haiku 4.5 to keep the per-run cost under a cent.
ANTHROPIC_API_KEY=sk-ant-replace-me

# ---------------------------------------------------------------------------
# Agent Runtime (apps/agent-runtime — dev HTTP shim on :4001)
# ---------------------------------------------------------------------------
# The runtime is a library; the `dev` script wraps it in a tiny
# Fastify server that serves /health. Override only if you have a
# port clash.
FORA_RUNTIME_PORT=4001
FORA_RUNTIME_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Master Orchestrator (apps/orchestrator — :4000)
# ---------------------------------------------------------------------------
FORA_ORCHESTRATOR_PORT=4000
FORA_ORCHESTRATOR_HOST=0.0.0.0
FORA_DEFAULT_COST_CEILING_USD=100.00
FORA_ORCHESTRATOR_LOG_LEVEL=info
FORA_ENV=dev
# NATS is the production event bus; the local stack does not boot
# NATS, so the orchestrator falls back to the in-process bus. To
# wire a real NATS container, set FORA_NATS_URL to its address and
# the orchestrator will connect (FORA-136 — the bus package — owns
# the integration). Leave unset in dev to use the log-only stub.
# FORA_NATS_URL=nats://localhost:4222

# ---------------------------------------------------------------------------
# Forge AI Console (apps/forge — :3000, FORA-374)
# ---------------------------------------------------------------------------
# Next.js 15 dev server. `pnpm --filter @fora/forge dev` picks these up.
# The console reads the orchestrator REST API from FORA_FORGE_API_URL;
# the same URL is exposed to the browser as NEXT_PUBLIC_FORGE_API_URL.
# Override only if you have a port clash with another tool.
FORA_FORGE_PORT=3000
FORA_FORGE_HOST=0.0.0.0
FORA_FORGE_API_URL=http://localhost:4000
NEXT_PUBLIC_FORGE_API_URL=http://localhost:4000
# Demo run id the persona dashboards render when no runs are indexed yet
# (the orchestrator 0.1.x does not expose GET /v1/runs). Set to an empty
# string to render the "no runs visible" empty state.
FORA_SEED_RUN_ID=demo-run-001

# ---------------------------------------------------------------------------
# Customer Cloud Broker (apps/customer-cloud-broker — :4003)
# ---------------------------------------------------------------------------
FORA_CCB_LISTEN_HOST=0.0.0.0
FORA_CCB_LISTEN_PORT=4003
# The broker is OIDC-issued; the dev `start.ts` accepts any URL
# here but `buildServer` will refuse to bind without a valid
# `FORA_CCB_PUBLIC_URL` so this is the URL the orchestrator uses
# to reach the broker.
FORA_CCB_PUBLIC_URL=http://localhost:4003
FORA_CCB_ISSUER=http://localhost:4003
FORA_CCB_AUDIENCE=customer-cloud-broker
FORA_CCB_BROKER_AUDIENCE=customer-cloud-broker
FORA_CCB_DENY_LIST_PATH=config/customer-cloud-broker/deny_list.yaml
FORA_CCB_TENANT_TRUST_ROOT=tenants
FORA_CCB_AUDIT_LOG_PATH=.fora/audit/customer-cloud-broker.jsonl
FORA_CCB_ENV=development
# Canary probe signer (FORA-126.4). The dev key is a 32-byte
# placeholder; production loads from Secrets Manager.
FORA_CCB_PROBE_SIGNING_KEY=dev-probe-signing-key-change-me-32bytes!
FORA_CCB_PROBE_INTERVAL_MS=300000
# SonarQube adapter token (FORA-321). Leave blank in dev unless
# you have a real SonarQube.
SONARQUBE_BROKER_TOKEN=

# ---------------------------------------------------------------------------
# Session tokens (packages/session-tokens — HS256 signing key)
# ---------------------------------------------------------------------------
# MUST be at least 32 bytes for HS256. `dev` is a placeholder;
# production uses the identity-broker's KMS-wrapped key.
SESSION_TOKENS_SIGNING_KEY=dev-only-session-tokens-signing-key-32+bytes

# ---------------------------------------------------------------------------
# Audit (packages/cache-broker/audit, packages/db-migrator)
# ---------------------------------------------------------------------------
# 0 = disable file-sink audit; 1 = enable (default in dev).
FORA_AUDIT_ENABLED=1
FORA_AUDIT_LOG=.fora/audit/tenancy-denied.jsonl

# ---------------------------------------------------------------------------
# Tenant seed — the demo tenant the AC asserts exists in Postgres.
# ---------------------------------------------------------------------------
# The first time the migrator runs it seeds exactly one tenant:
# `acme-corp` with policy "public-preview" so the dashboard has
# something to render. The seed is idempotent — re-running is a
# no-op.
FORA_SEED_TENANT_ID=acme-corp
FORA_SEED_TENANT_NAME="Acme Corp (Dev Demo)"
FORA_SEED_TENANT_POLICY=public-preview
