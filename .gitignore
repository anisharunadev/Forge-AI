# Contains ANTHROPIC_API_KEY.
# Never commit.
# archive/**
.env
.env.*
!.env.example

# Local dev runtime state (logs, pids, evidence)
.fora/logs/
.fora/pids/

# Tooling scratch
.omc/
.serena/

# Archived historical code (Paperclip era) — not deployed.
# M1 T1.5 exception: the legacy Keycloak realm archive IS tracked so
# the canonicalization step leaves an audit trail of what got demoted.
# Use a glob so descendants of archive/keycloak-init-legacy can be
# re-included via the `!` rules below (negation does not un-anchor
# a top-level directory pattern).
archive/*
!archive/keycloak-init-legacy/
!archive/keycloak-init-legacy/**

# Node build artefacts
node_modules/
**/dist/
**/node_modules/
**/.vite/

# Python artefacts
__pycache__/
*.pyc

# Smoke runs / dev artefacts
**/workspace/runs/*.json
**/workspace/runs/*.jsonl

# Vitest results
**/vitest/results.json
