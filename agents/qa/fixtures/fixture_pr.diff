@@ -0,0 +1,14 @@
+"""Checkout entry point (FORA fixture)."""
+from __future__ import annotations
+
+from .idempotency import is_replay, IDEMPOTENCY_TTL_SECONDS
+
+
+def charge(token: str, amount_cents: int, seen_tokens: set[str]) -> dict:
+    if is_replay(token, seen_tokens):
+        return {"status": "duplicate", "token": token}
+    return {"status": "ok", "token": token, "amount_cents": amount_cents}
+
+
+def ttl_seconds() -> int:
+    return IDEMPOTENCY_TTL_SECONDS
