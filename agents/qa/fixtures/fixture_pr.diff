@@ -0,0 +1,12 @@
+"""Idempotency store for the checkout service (FORA fixture)."""
+from __future__ import annotations
+
+import time
+
+IDEMPOTENCY_TTL_SECONDS = 24 * 60 * 60
+
+
+def is_replay(token: str, seen_tokens: set[str]) -> bool:
+    """Return True if `token` was already processed within the TTL window."""
+    if token in seen_tokens:
+        return True
+    seen_tokens.add(token)
+    return False
+
+
+def now_seconds() -> int:
+    return int(time.time())
