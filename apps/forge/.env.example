# F-800 — Forge Co-pilot (frontend flags)
#
# NEXT_PUBLIC_* vars are inlined into the client bundle at build time
# (Next.js inlines any env var prefixed with NEXT_PUBLIC_). These are
# read in `lib/feature-flags.ts` as the SSR-safe fallback when the
# backend `/api/v1/system/features` endpoint is unreachable.
#
# The canonical source of truth is the backend `Settings` (read from
# the same env vars without the NEXT_PUBLIC_ prefix); the frontend
# values here MUST match `backend/.env.example` so the SSR default
# agrees with the backend's authoritative flag set.

# Master toggle — when False, the Cmd+J hotkey is ignored and the
# panel renders nothing. Backend must agree (see backend/.env.example).
NEXT_PUBLIC_COPILOT_ENABLED=true

# V1.1 deferred — always false in V1.
NEXT_PUBLIC_COPILOT_STREAMING=false

# Per-conversation budget ceiling (USD). The backend creates a
# synthetic WorkflowBudget row with this ceiling when a conversation
# starts.
NEXT_PUBLIC_COPILOT_DEFAULT_BUDGET_USD=1.00

# Hard cap on tool-call turns per agent loop invocation. When the
# loop exceeds this, the API returns 503 with `tool_loop_exhausted`.
NEXT_PUBLIC_COPILOT_TOOL_CALL_MAX=5

# Per-user request cap (POST /copilot/conversations). 429 with
# Retry-After when the cap is hit (Plan 5).
NEXT_PUBLIC_COPILOT_RATE_LIMIT_PER_MIN=10
