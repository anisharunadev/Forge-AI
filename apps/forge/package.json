{
  "name": "forge-dashboard",
  "version": "0.1.0",
  "description": "Forge AI console \u2014 Next.js 15 persona dashboards (PM / Engineering Lead / CTO / VP Eng) + run timeline UI, backed by the orchestrator REST API (FORA-374).",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "start": "next start -p ${FORA_FORGE_PORT:-3000} -H ${FORA_FORGE_HOST:-0.0.0.0}",
    "dev": "next dev -p ${FORA_FORGE_PORT:-3000} -H ${FORA_FORGE_HOST:-0.0.0.0}",
    "dev:stub": "python3 bin/orchestrator-stub.py",
    "dev:terminal": "node bin/terminal-server.mjs",
    "dev:stack": "concurrently -n stub,term,ui -c magenta,cyan,green \"pnpm dev:stub\" \"pnpm dev:terminal\" \"pnpm dev\"",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.59.16",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.453.0",
    "next": "15.0.3",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106",
    "reactflow": "^11.11.4",
    "recharts": "^2.13.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.48.0",
    "@testing-library/react": "16.0.1",
    "@testing-library/dom": "10.4.0",
    "@types/node": "22.5.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "concurrently": "^9.0.1",
    "jsdom": "25.0.1",
    "node-pty": "^1.0.0",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.9.2",
    "vitest": "2.1.0",
    "ws": "^8.18.0"
  }
}
