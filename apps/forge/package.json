{
  "name": "@fora/forge",
  "version": "0.1.0",
  "description": "FORA Forge AI console — Next.js 15 persona dashboards (PM / Engineering Lead / CTO / VP Eng) + run timeline UI, backed by the orchestrator REST API (FORA-374).",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "start": "next start -p ${FORA_FORGE_PORT:-3000} -H ${FORA_FORGE_HOST:-0.0.0.0}",
    "dev": "next dev -p ${FORA_FORGE_PORT:-3000} -H ${FORA_FORGE_HOST:-0.0.0.0}",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106"
  },
  "devDependencies": {
    "@playwright/test": "1.48.0",
    "@testing-library/react": "16.0.1",
    "@testing-library/dom": "10.4.0",
    "@types/node": "22.5.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "4.3.3",
    "autoprefixer": "10.4.20",
    "jsdom": "25.0.1",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.14",
    "typescript": "5.9.2",
    "vitest": "2.1.0"
  }
}