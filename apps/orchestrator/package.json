{
  "name": "@fora/orchestrator",
  "version": "0.1.0",
  "description": "FORA Master Orchestrator — session lifecycle endpoints (create / pause / resume / cancel), idempotency, durable crash recovery. Implements FORA-134 (0.1.1).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fora-orchestrator": "bin/fora-orchestrator.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node bin/fora-orchestrator.mjs",
    "dev": "node --watch bin/fora-orchestrator.mjs",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fora/db-migrator": "workspace:*",
    "@fora/db-pool": "workspace:*",
    "@fora/event-bus": "workspace:*",
    "fastify": "^5.0.0",
    "nats": "^2.28.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
