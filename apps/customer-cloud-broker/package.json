{
  "name": "@fora/customer-cloud-broker",
  "version": "0.1.0",
  "description": "FORA customer-cloud-broker — brokered OIDC federation to AWS / Azure / GCP. FORA-126 / 0.7.4. Implements ADR-0003 §6.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fora-customer-cloud-broker": "bin/fora-customer-cloud-broker.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node bin/fora-customer-cloud-broker.mjs",
    "dev": "node --watch bin/fora-customer-cloud-broker.mjs",
    "test": "vitest run",
    "smoke": "node test/smoke.mjs"
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@aws-sdk/client-cloudcontrol": "^3.658.0",
    "@aws-sdk/client-cloudformation": "^3.658.0",
    "@aws-sdk/client-ec2": "^3.658.0",
    "@aws-sdk/client-iam": "^3.658.0",
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/client-sts": "^3.658.0",
    "@azure/core-auth": "^1.7.0",
    "@azure/identity": "^4.5.0",
    "@fora/session-tokens": "workspace:*",
    "@google-cloud/compute": "^4.0.0",
    "@google-cloud/resource-manager": "^5.0.0",
    "@google-cloud/storage": "^7.0.0",
    "fastify": "^5.0.0",
    "google-auth-library": "^9.0.0",
    "jose": "^5.9.6",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "fast-check": "^3.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
