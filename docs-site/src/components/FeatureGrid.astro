---
/**
 * FeatureGrid.astro — wrapper for a grid of FeatureCards
 *
 *   <FeatureGrid cols={3}>
 *     <FeatureCard ... />
 *     <FeatureCard ... />
 *   </FeatureGrid>
 */
export interface Props {
  cols?: 2 | 3 | 4;
}
const { cols = 3 } = Astro.props;
---
<div class={`feature-grid cols-${cols}`}>
  <slot />
</div>
