---
/**
 * Icon.astro — Tiny inline SVG icon set (Lucide-style)
 *
 * Avoids a JS dependency. Each icon is a 24x24 stroke=2 path that
 * follows Lucide's geometry. Use `<Icon name="layers" />` in MDX.
 */
export interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
  color?: string;
}

const { name, size = 20, class: className = '', strokeWidth = 2, color = 'currentColor' } = Astro.props;

const paths: Record<string, string> = {
