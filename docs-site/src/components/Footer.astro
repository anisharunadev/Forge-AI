const heartIcon = `<svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color:#e25555;vertical-align:-2px"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>`;
---

<div class="sl-flex sl-flex-col sl-gap-3">
  <div class="sl-flex sl-flex-wrap sl-gap-3 sl-items-center">
    <a href="https://github.com/fora-platform/fora" class="sl-flex sl-items-center sl-gap-1.5">
      <span set:html={githubIcon} /> Forge AI
    </a>
    <a href="/reference/glossary">Glossary</a>
    <a href="/reference/adr">ADRs</a>
    <a href="https://status.forge-ai.dev" target="_blank" rel="noopener">Status</a>
  </div>
  <p class="source-line">
    Every page on this site is generated from the Forge AI <a href="https://github.com/fora-platform/fora/tree/main/workspace">Knowledge Layer</a>
    (<code>workspace/</code>) — the storage contract is <a href="https://github.com/fora-platform/fora/blob/main/workspace/project/docs.md">docs.md</a>.
    A re-run with the same inputs is a byte-identical no-op (idempotency contract).
  </p>
  <p class="meta">
    © 2026 Knackforge · Forge AI is the enterprise-grade SDLC agent from <a href="https://knackforge.com">Knackforge</a> · Made with <span set:html={heartIcon} /> and <a href="https://astro.build">Astro</a>
  </p>
</div>

<style>
  .source-line,
  .meta {
    margin: 0;
    font-size: 0.825rem;
    color: var(--sl-color-gray-3);
  }
  .source-line code {
    font-size: 0.85em;
    background: var(--sl-color-gray-6);
    padding: 0.05em 0.35em;
    border-radius: 3px;
  }
</style>
