    }
  ],
  "risk_register": [
    {
      "title": "...",
      "description": "...",
      "likelihood": 0.0,
      "impact": 0.0,
      "severity": 0.0,
      "mitigation": "...",
      "owner": "...",
      "tags": ["..."]
    }
  ],
  "effort_estimate": {
